# MongoDB Connection
connectDBUsers=mongodb+srv://usuario:password@cluster.mongodb.net/kuche_db?retryWrites=true&w=majority

# JWT Secret
TOKEN_SECRET=tu_secret_key_super_segura_aqui

# DigitalOcean Spaces Configuration (compatible con AWS S3)
DO_SPACES_ENDPOINT=nyc3.digitaloceanspaces.com
DO_SPACES_KEY=tu_access_key_aqui
DO_SPACES_SECRET=tu_secret_key_aqui
DO_SPACES_BUCKET=kuche-files

# AWS S3 (si migras después, solo descomenta y usa estas)
# AWS_S3_REGION=us-east-1
# AWS_S3_ACCESS_KEY=tu_access_key_aqui
# AWS_S3_SECRET_KEY=tu_secret_key_aqui
# AWS_S3_BUCKET=kuche-files

# Node Environment
NODE_ENV=development

# Port
PORT=4000

# Frontend URLs (para CORS)
FRONTEND_URL=http://localhost:5173
